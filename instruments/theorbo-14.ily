\version "2.24.0"

% 14-Course Theorbo
% Courses 1-6: fretted (first two courses re-entrant at A3/E3)
% Courses 7-14: diapasons (unfretted bass)

theorboStringTunings = \stringTuning <a e b, g, d, a,,>

% Diapasons — listed highest to lowest (7→14)
theorboDiapasons = \stringTuning <g,, f,, e,, d,, c,, bes,,, a,,, g,,,>

theorboTabFormat = #fret-letter-tablature-format
