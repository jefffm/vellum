\version "2.24.0"

% 14-Course Theorbo
% Courses 1-6: fretted (first course off the neck at A3, re-entrant)
% Courses 7-14: diapasons (unfretted bass)

theorboStringTunings = \stringTuning <a f c a, f, d,>

% Diapasons — listed highest to lowest (7→14)
theorboDiapasons = \stringTuning <c, bes,, aes,, g,, f,, ees,, d,, c,,>

theorboTabFormat = #fret-letter-tablature-format
