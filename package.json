{
  "name": "vellum",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "node scripts/dev-all.mjs",
    "server:build": "tsc -p tsconfig.server.json",
    "server": "node dist-server/server/index.js",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "spec:verify": "node scripts/verify-spec-reconciliation.mjs && node scripts/verify-arrangement-intelligence.mjs",
    "spec:arrangement-intelligence": "node scripts/verify-arrangement-intelligence.mjs",
    "spec:arrangement-intelligence:complete": "node scripts/verify-arrangement-intelligence.mjs --complete",
    "sandbox:lilypond:verify": "node scripts/verify-lilypond-sandbox.mjs"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.70.2",
    "@mariozechner/pi-ai": "^0.70.2",
    "@mariozechner/pi-web-ui": "^0.70.2",
    "@sinclair/typebox": "^0.34.38",
    "dompurify": "^3.4.12",
    "express": "^5.1.0",
    "js-yaml": "^4.1.0",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "tonal": "^6.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.15.3",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
