{
  "name": "vellum",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "node scripts/dev-all.mjs",
    "server:build": "node scripts/clean-server-build.mjs && tsc -p tsconfig.server.json && node scripts/verify-server-build.mjs",
    "server": "node dist-server/server/index.js",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "test:browser": "playwright test",
    "test:watch": "vitest",
    "proof:baseline": "VELLUM_PRINT_MUSICAL_PROOF_BASELINE=1 vitest run test/e2e/old-hundredth-three-target-baseline.test.ts",
    "proof:musical": "node scripts/run-musical-regressions.mjs",
    "proof:holdout": "npm run server:build --silent && node dist-server/server/private-holdout-cli.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "spec:verify": "node scripts/verify-current-spec.mjs && node scripts/verify-arrangement-intelligence.mjs",
    "authority-paths:verify": "node scripts/build-authority-path-inventory.mjs",
    "authority-paths:refresh": "node scripts/build-authority-path-inventory.mjs --write",
    "history:arrangement-intelligence:verify": "node scripts/verify-arrangement-intelligence.mjs",
    "history:arrangement-intelligence:complete": "node scripts/verify-arrangement-intelligence.mjs --complete",
    "sandbox:lilypond:verify": "node scripts/verify-lilypond-sandbox.mjs && VELLUM_REAL_LILYPOND_SANDBOX=1 vitest run src/server/lib/podman-lilypond-runner.test.ts test/e2e/greensleeves-tracer.test.ts",
    "eval:fast": "npm run server:build --silent && node dist-server/server/evaluation-cli.js",
    "eval:golden": "npm run server:build --silent && node dist-server/server/golden-evaluation-cli.js",
    "eval:parity": "npm run server:build --silent && node dist-server/server/three-target-parity-cli.js",
    "eval:omr": "npm run server:build --silent && node dist-server/server/external-evaluation-cli.js --kind omr",
    "eval:model": "npm run server:build --silent && node dist-server/server/external-evaluation-cli.js --kind model",
    "eval:render": "npm run server:build --silent && node dist-server/server/render-playback-evaluation-cli.js --kind render",
    "eval:playback": "npm run server:build --silent && node dist-server/server/render-playback-evaluation-cli.js --kind playback",
    "eval:report": "npm run server:build --silent && node dist-server/server/evaluation-report-cli.js",
    "eval:compare": "npm run server:build --silent && node dist-server/server/evaluation-comparison-cli.js",
    "review:validate": "npm run server:build --silent && node dist-server/server/review-attestation-cli.js"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.73.1",
    "@mariozechner/pi-ai": "^0.73.1",
    "@mariozechner/pi-web-ui": "^0.73.1",
    "@sinclair/typebox": "^0.34.38",
    "dompurify": "^3.4.12",
    "express": "^5.1.0",
    "js-yaml": "^4.1.0",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "pdfkit": "0.17.2",
    "svg-to-pdfkit": "0.1.8",
    "tonal": "^6.4.3",
    "verovio": "6.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/express": "^5.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.15.3",
    "@types/pdfkit": "0.17.5",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vite-node": "^3.2.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
