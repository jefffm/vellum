      "remove-only-run-scoped-generated-output-and-caches",
      "create-new-empty-run-scoped-mutable-store",
      "record-toolchain-hardware-os-and-fixture-identities",
      "run-warmups-without-retaining-observations",
      "run-measured-repetitions-with-monotonic-clock-and-peak-rss-sampling",
      "release-leases-after-artifact-digests-and-cleanup-receipt-are-durable"
    ],
    "forbidSharedWarmCaches": true,
    "requireFreshMutableStore": true,
    "requireOrphanAbsenceProof": true,
    "requireCleanRerunAfterOrphanCleanup": true
