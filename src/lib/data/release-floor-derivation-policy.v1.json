  "resultRules": {
    "unsupportedHardware": "blocked",
    "differentRecordedHost": "incomparable",
    "toolchainMismatch": "incomparable",
    "missingMetric": "blocked",
    "referenceBudgetExhaustion": "fail",
    "stressBudgetExhaustion": "actionable-only"
