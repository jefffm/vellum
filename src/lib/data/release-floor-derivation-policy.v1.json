    "contentPolicy": "bounded-redacted-tail-only",
    "forbidPrivatePaths": true,
    "forbidSourceBytes": true,
    "forbidProviderPayloads": true,
    "thresholdFamily": "redacted-diagnostic-bytes"
  },
