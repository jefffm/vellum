    {
      "id": "reviewed-owner-default-persistence-closure",
      "sourcePath": "src/server/lib/reviewed-owner-default-bridge.ts",
      "sinkSelectors": ["proposeDefaultCandidate"],
      "allowedRoots": []
    },
    {
      "id": "three-target-evaluation-runner-persistence-closure",
      "sourcePath": "src/server/lib/three-target-parity.ts",
      "sinkSelectors": ["run"],
      "allowedRoots": []
    },
    {
      "id": "workspace-persistence-closure",
      "sourcePath": "src/server/lib/workspace-store.ts",
      "sinkSelectors": [
        "WorkspaceStore.linkWorkspaceRecord",
        "WorkspaceStore.writeImmutableRecord",
        "WorkspaceStore.writeRecord",
        "WorkspaceStore.writeWorkspace",
        "writeJsonAtomic"
      ],
      "allowedRoots": [
        {
          "selector": "WorkspaceStore.rename",
          "reason": "Renaming changes only the owner-visible workspace title and concurrency revision; it does not alter musical behavior or an authority claim."
        }
      ]
    }
  ],
