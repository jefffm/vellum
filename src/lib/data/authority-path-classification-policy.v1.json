    {
      "id": "owner-playtest-persistence-closure",
      "sourcePath": "src/server/lib/owner-playtest-route.ts",
      "sinkSelectors": ["saveOwnerPlaytest"],
      "allowedRoots": []
    },
    {
      "id": "reviewed-learning-persistence-closure",
      "sourcePath": "src/server/lib/reviewed-learning.ts",
      "sinkSelectors": [
        "saveEvaluatorDatasetManifest",
        "saveEvaluatorRevision",
        "saveReviewedLearningDecision",
        "saveReviewedLearningOutputCandidate",
