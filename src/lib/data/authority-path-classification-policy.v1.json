      "id": "owner-reference-workbench-local-study-service-persistence-closure",
      "sourcePath": "src/server/lib/owner-reference-workbench-service.ts",
      "sinkSelectors": ["execute"],
      "allowedRoots": [
        {
          "selector": "OwnerReferenceWorkbenchService.reviewLocalOperation",
          "reason": "This guarded review path supplies fixed effects that throw on byte reads or sink writes and supplies no allow capability, so the gateway cannot execute an authority-bearing effect."
        }
