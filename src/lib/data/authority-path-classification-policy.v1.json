    {
      "id": "reference-source-operation-route-output-closure",
      "sourcePath": "src/server/lib/reference-source-operation-route.ts",
      "sinkSelectors": ["execute", "executeCompilerInput"],
      "allowedRoots": [
        {
          "selector": "createReferenceSourceCompilerInputRoute",
          "reason": "The compiler-input adapter method hard-codes capability resolution off, so the gateway cannot read controlled bytes or invoke the sink."
        },
        {
          "selector": "createReferenceSourceOperationDefaultDecisionRoute",
          "reason": "This decision-only route constructs a gateway without an allow verifier and supplies fixed effects that throw on byte reads or sink writes."
